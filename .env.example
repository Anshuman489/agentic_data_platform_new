# ─────────────────────────────────────────────────────────────────────────────
# Agentic Data Intelligence Platform — Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in your values in .env
#   3. Never commit .env to version control (it is in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────


# ── Google Cloud ──────────────────────────────────────────────────────────────

# The GCP project ID that owns the BigQuery tables you want to query.
# Find this in the GCP Console under "Project Info".
GCP_PROJECT=your-gcp-project-id

# The BigQuery geographic region where your datasets live.
# Common values: US, EU, us-central1, europe-west2
# Must match the region of your BigQuery dataset — queries fail if this is wrong.
BQ_LOCATION=US


# ── Schema Profiling ──────────────────────────────────────────────────────────

# Number of rows to fetch when sampling a table.
# These rows are used to extract example column values.
# 10 is enough for V1 — increase later if richer sampling is needed.
BQ_SAMPLE_ROW_LIMIT=10

# Cardinality threshold for classifying a STRING column as a DIMENSION vs FREE_TEXT.
# If a string column has fewer distinct values than this → DIMENSION (e.g. "region", "status")
# If it has more → FREE_TEXT or IDENTIFIER
DIMENSION_CARDINALITY_THRESHOLD=100

# Cardinality threshold for classifying a NUMERIC column as a DIMENSION vs MEASURE.
# If a numeric column has fewer distinct values than this → DIMENSION (e.g. "rating" with values 1–5)
# If it has more → MEASURE (e.g. "revenue", "quantity")
MEASURE_CARDINALITY_THRESHOLD=50


# ── LLM — Vertex AI (Gemini) ──────────────────────────────────────────────────

# Vertex AI region for Gemini model calls.
# Use "us-central1" for a specific region (cheapest, broadest model availability).
# Use "us" or "eu" for multi-region routing (+10% price premium).
# Use "global" for maximum availability (dynamic routing, no premium).
VERTEX_LOCATION=us-central1

# Gemini model ID to use for all LLM agents.
# Cheaper options:  gemini-2.0-flash-lite-001
# Default balance:  gemini-2.0-flash-001
# Best quality:     gemini-2.5-flash  |  gemini-2.5-pro
LLM_MODEL=gemini-2.5-flash


# ── Cache ─────────────────────────────────────────────────────────────────────

# Directory where DatasetProfile JSON files are stored after profiling.
# Relative paths are resolved from the project root.
# The directory is created automatically if it does not exist.
CACHE_DIR=./cache

# How many hours a cached DatasetProfile stays valid before re-profiling.
# Set to 0 to always re-profile (useful during development).
CACHE_MAX_AGE_HOURS=24
